# ──────────────────────────────────────────────────────────
# Supabase
# ──────────────────────────────────────────────────────────

# Your Supabase project URL (Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key (Settings → API → anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key

# Supabase service role key (Settings → API → service_role secret)
# ⚠️  NEVER expose this to the browser — server-side API routes only
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# ──────────────────────────────────────────────────────────
# OpenRouter
# ──────────────────────────────────────────────────────────

# Your OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-...your-key

# ──────────────────────────────────────────────────────────
# Cron (daily summarization)
# ──────────────────────────────────────────────────────────

# Secret token to authenticate cron requests
# Generate with: openssl rand -hex 32
CRON_SECRET=your-random-secret-here